{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://yolovibescode.org/yoloterm/theme.schema.json",
  "title": "YOLOTerm Theme",
  "description": "Color theme for YOLOTerm terminal (all tracks)",
  "type": "object",
  "required": ["id", "name", "background", "foreground", "cursor", "cursorAccent", "selectionBackground"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON schema reference"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Unique theme identifier (kebab-case)"
    },
    "name": {
      "type": "string",
      "description": "Human-readable theme name"
    },
    "description": {
      "type": "string",
      "description": "Theme description (optional)"
    },
    "background": {
      "type": "string",
      "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$",
      "description": "Background color (hex RGB or RGBA)"
    },
    "foreground": {
      "type": "string",
      "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$",
      "description": "Foreground (text) color (hex RGB or RGBA)"
    },
    "cursor": {
      "type": "string",
      "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$",
      "description": "Cursor color (hex RGB or RGBA)"
    },
    "cursorAccent": {
      "type": "string",
      "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$",
      "description": "Cursor text/accent color (hex RGB or RGBA)"
    },
    "selectionBackground": {
      "type": "string",
      "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$",
      "description": "Selection background color (hex RGB or RGBA)"
    },
    "useDefaultAnsi": {
      "type": "boolean",
      "description": "If true, ANSI-16 colors use terminal's built-in vivid palette (no ansiColors overlay). Default: false",
      "default": false
    },
    "ansiColors": {
      "type": "object",
      "description": "Optional ANSI-16 color palette overlay (omit if useDefaultAnsi is true)",
      "required": [
        "black", "red", "green", "yellow", "blue", "magenta", "cyan", "white",
        "brightBlack", "brightRed", "brightGreen", "brightYellow", "brightBlue", "brightMagenta", "brightCyan", "brightWhite"
      ],
      "properties": {
        "black": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$" },
        "red": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$" },
        "green": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$" },
        "yellow": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$" },
        "blue": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$" },
        "magenta": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$" },
        "cyan": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$" },
        "white": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$" },
        "brightBlack": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$" },
        "brightRed": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$" },
        "brightGreen": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$" },
        "brightYellow": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$" },
        "brightBlue": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$" },
        "brightMagenta": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$" },
        "brightCyan": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$" },
        "brightWhite": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}([0-9a-fA-F]{2})?$" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
